# Virtual environments (unified services/.venv or per-package)
.venv/
venv/
**/.venv/

# Secrets — never commit API keys
.env
.env.local
.env.*.local
!.env.example

# Python bytecode and packaging
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg

# Test / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Scrape / audit / outreach run outputs (keep folder placeholders)
**/output/*
!**/output/.gitkeep

# Playwright (if installed inside project tree)
.playwright/

# OS / editor noise
.DS_Store
Thumbs.db
